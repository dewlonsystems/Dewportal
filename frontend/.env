# ==============================================================================
# DEWPORTAL FRONTEND - ENVIRONMENT VARIABLES
# ==============================================================================
# Copy this file to .env.local and fill in values. NEVER commit .env.local.
# ==============================================================================

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# M2M Authentication (for Server Actions to Django)
# These are used by Next.js Server Actions, NOT exposed to browser
SYSTEM_API_KEY=yLJ9tm34ytmPo-c8FEk58ZGwyl8BsRUZ0Q2CUw3_FYM
NEXTJS_PRIVATE_KEY_PATH=./keys/nextjs_private.pem

JWT_VERIFYING_KEY="-----BEGIN PUBLIC KEY-----\\n-----END PUBLIC KEY-----"

# Application Settings
NEXT_PUBLIC_APP_NAME=Dewlon Portal
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags
NEXT_PUBLIC_ENABLE_MPESA=true
NEXT_PUBLIC_ENABLE_PAYSTACK=true
NEXT_PUBLIC_ENABLE_DEBUG=false

# WebSocket Settings
NEXT_PUBLIC_WS_HEARTBEAT_INTERVAL=30000
NEXT_PUBLIC_WS_RECONNECT_INTERVAL=5000

# Session Settings
NEXT_PUBLIC_SESSION_TIMEOUT=900000